#!/usr/bin/env bash
#:  `raocow`
#:
#:  Summarize raocow/tap: each tool, what it's for, and its install state.
#:  For per-command docs, see the tool's own help (e.g. `git sweep -h`,
#:  `ezenv --help`).
#:
#:  Usage:
#:    brew raocow            summarize the tap
#:    brew raocow --help     show this help
set -euo pipefail

# Reads files + Homebrew's env vars only — no `brew` subprocess (each costs
# ~0.5s of Ruby startup + formula loading).
repo="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cellar="${HOMEBREW_CELLAR:-${HOMEBREW_PREFIX:-/opt/homebrew}/Cellar}"

shopt -s nullglob
formulae=("$repo"/Formula/*.rb)

field() {  # field <regex-capturing-value> <file>
  sed -n "s/^[[:space:]]*$1/\1/p" "$2" | head -1
}
tap_version() {  # explicit `version "..."`, else the vX.Y.Z tag in `url`
  local f="$1" v
  v="$(field 'version "\(.*\)"' "$f")"
  [ -n "$v" ] || v="$(sed -n 's#.*/tags/v\{0,1\}\([0-9][^"/]*\)\.tar\.gz.*#\1#p' "$f" | head -1)"
  echo "$v"
}
installed_version() {  # highest version dir in the Cellar, empty if none
  local dirs=("$cellar/$1"/*/)
  [ ${#dirs[@]} -gt 0 ] || return 0
  printf '%s\n' "${dirs[@]}" | xargs -n1 basename | sort -V | tail -1
}
# Editorial purpose blurb per tool (falls back to the formula desc otherwise).
purpose() {
  case "$1" in
    gtools) cat <<'P'
Custom git subcommands for a PR-based team workflow. git sweep clears merged
branches (quicker than asking an LLM to); git pr / git here / git done check
out, test, and tear down a coworker's PR; git sync rebases and pushes.
Per-command help: git <cmd> -h  (or the man page: git <cmd> --help)
P
    ;;
    ezenv) cat <<'P'
Opt-in zsh environment helpers for a fresh Mac: per-repo .venv auto-activation
and bare python/pip -> python3/pip3, each enabled a la carte with one command
— no dotfile spelunking, nothing on until you ask for it.
Per-feature help: ezenv --help
P
    ;;
  esac
}

echo "raocow/tap — a few small tools to make a fresh Mac feel like home"
echo "A personal Homebrew tap: shortcuts I trust and reach for every day, so a"
echo "new machine is one 'brew install' away from feeling like home."
echo

for f in "${formulae[@]}"; do
  name="$(basename "$f" .rb)"
  home="$(field 'homepage "\(.*\)"' "$f")"
  latest="$(tap_version "$f")"
  inst="$(installed_version "$name")"

  if [ -z "$inst" ]; then
    state="not installed — latest $latest"
  elif [ -n "$latest" ] && [ "$inst" != "$latest" ] \
       && [ "$(printf '%s\n%s\n' "$inst" "$latest" | sort -V | tail -1)" = "$latest" ]; then
    state="installed $inst — upgrade to $latest available"
  else
    state="installed $inst (current)"
  fi

  echo "  $name — $state"
  [ -n "$home" ] && echo "      $home"
  blurb="$(purpose "$name")"; [ -n "$blurb" ] || blurb="$(field 'desc "\(.*\)"' "$f")"
  echo "$blurb" | sed 's/^/      /'
  echo
done

echo "Install: brew install <formula>   Upgrade: brew upgrade <formula>   Details: brew info <formula>"
